with "libadalang";

project Lal_Api is
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("libadalang_api_generator.adb");

   package Builder is
      for Executable ("libadalang_api_generator.adb") use "lal_api";
   end Builder;

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-g", "-O0", "-gnatwa");
   end Compiler;
end Lal_Api;
