{
  "runs": [
    {
      "invocations": [
        {
          "arguments": [
            "-q",
            "-P",
            "prj.gpr",
            "--sarif=<working-dir>/gnatcheck.sarif",
            "--rules-dir=./",
            "--show-rule",
            "-rules"
          ],
          "commandLine": "COMMAND_LINE",
          "endTimeUtc": "END_TIME",
          "environmentVariables": "ENV_VARS",
          "executionSuccessful": true,
          "exitCode": 1,
          "startTimeUtc": "START_TIME",
          "workingDirectory": {
            "uri": "WORKING_DIR"
          }
        }
      ],
      "originalUriBaseIds": {
        "URI_BASE_DIR": {
          "description": {
            "text": "Project directory if one has been used, working directory otherwise"
          },
          "uri": "BASE_URI"
        }
      },
      "results": [
        {
          "level": "warning",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "main.adb",
                  "uriBaseId": "URI_BASE_DIR"
                },
                "region": {
                  "startColumn": 4,
                  "startLine": 3
                }
              }
            }
          ],
          "message": {
            "text": "My custom rule [Other_Instance|custom]"
          },
          "ruleId": "other_instance"
        },
        {
          "level": "warning",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "main.adb",
                  "uriBaseId": "URI_BASE_DIR"
                },
                "region": {
                  "startColumn": 4,
                  "startLine": 3
                }
              }
            }
          ],
          "message": {
            "text": "My custom rule [custom]"
          },
          "ruleId": "custom"
        }
      ],
      "tool": {
        "driver": {
          "informationUri": "https://docs.adacore.com/live/wave/lkql/html/gnatcheck_rm/gnatcheck_rm.html",
          "name": "gnatcheck",
          "organization": "AdaCore",
          "rules": [
            {
              "defaultConfiguration": {
                "enabled": true,
                "parameters": {}
              },
              "help": {
                "text": "A little bit of help"
              },
              "id": "custom",
              "name": "custom",
              "shortDescription": {
                "text": "My custom rule"
              }
            },
            {
              "defaultConfiguration": {
                "enabled": true,
                "parameters": {
                  "bool": "true",
                  "int": "42",
                  "list": "[false, 0, /"also_from_instance/"]",
                  "str": "/"from_instance/""
                }
              },
              "id": "other_instance",
              "name": "Other_Instance",
              "relationships": [
                {
                  "target": {
                    "id": "custom"
                  }
                }
              ]
            }
          ],
          "version": "VERSION"
        }
      }
    }
  ],
  "version": "2.1.0"
}